NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/ecommerce

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your_access_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Firebase — download from Firebase Console > Project Settings > Service Accounts
# Option A: JSON file path (local dev) — place file at project root
# Option B: Paste the entire JSON as a single-line string (production)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Google OAuth (for raw Google token verification — One Tap on web)
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com